{
  "name": "nextgen-secure-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "oxlint src/ --deny-warnings -D correctness -D perf -D security",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "secure-build": "npm run lint && npm run test"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^9.7.4",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "oxlint": "^0.15.15",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
